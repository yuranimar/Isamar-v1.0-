# ════════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — isamar
# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env a Git (.gitignore ya lo excluye)
# ════════════════════════════════════════════════════════════════

# ── Sanity CMS (lectura pública — OK en cliente) ─────────────────
VITE_SANITY_PROJECT_ID=your-project-id     # sanity.io/manage → Project ID
VITE_SANITY_DATASET=production

# ── WhatsApp ──────────────────────────────────────────────────────
VITE_WHATSAPP_NUMBER=573215551234          # Sin + ni espacios

# ── Firebase Auth (login Google del panel admin) ──────────────────
# console.firebase.google.com → tu proyecto → Web app → firebaseConfig
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# ── Emails autorizados para el panel admin ────────────────────────
VITE_ADMIN_EMAILS=isamar@gmail.com

# ── Secret del panel admin ────────────────────────────────────────
# Cadena aleatoria que el panel envía al servidor para autenticar.
# Generar en: https://randomkeygen.com (CodeIgniter Encryption Keys)
# DEBE coincidir exactamente con ADMIN_SECRET en Vercel (sin VITE_)
VITE_ADMIN_SECRET=genera-un-string-aqui


# ════════════════════════════════════════════════════════════════
# VARIABLES SOLO PARA VERCEL (servidor) — NO van en .env local
# Agregar en: Vercel Dashboard → tu proyecto → Settings → Env Vars
# ════════════════════════════════════════════════════════════════

# Sanity con permiso de escritura — NUNCA con prefijo VITE_
# SANITY_PROJECT_ID=your-project-id
# SANITY_DATASET=production
# SANITY_WRITE_TOKEN=sk...   (sanity.io/manage → API → Tokens → Editor)

# El mismo secret que VITE_ADMIN_SECRET pero sin VITE_ (servidor lo valida)
# ADMIN_SECRET=genera-un-string-aqui

# Notificaciones por email (resend.com — gratis 3k/mes)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# NOTIFY_EMAIL_TO=isamar@gmail.com
# NOTIFY_EMAIL_FROM=noreply@isamar.co

# Cron mensual
# CRON_SECRET=otro-string-secreto
